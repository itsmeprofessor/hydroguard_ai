# ==============================================================================
#  HydroGuard-AI — Environment Variables Template
#  Copy to .env and fill in all REQUIRED values before running.
#  NEVER commit .env to version control — it contains secrets.
# ==============================================================================

# ── REQUIRED — application will refuse to start without these ─────────────────

# JWT signing key — must be cryptographically random, minimum 32 chars
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# PostgreSQL password (also used in DATABASE_URL below)
POSTGRES_PASSWORD=

# Redis auth password
REDIS_PASSWORD=

# Legacy admin token (for X-Admin-Token header auth, used by some dashboard flows)
ADMIN_TOKEN=

# ── OPTIONAL — have sensible defaults ─────────────────────────────────────────

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS — comma-separated allowed origins
# Use * only in development — with credentials it MUST be explicit origin(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — PostgreSQL for production, SQLite for local dev
DATABASE_URL=postgresql://hydroguard:${POSTGRES_PASSWORD}@postgres:5432/hydroguard
# DATABASE_URL=sqlite:///backend/weather_anomalies.db

# Redis (enables cross-worker WebSocket fan-out and rate-limit state sharing)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Live Weather API ───────────────────────────────────────────────────────────

# Provider: "auto" | "weatherapi" | "openweathermap" | "open-meteo"
# "auto" picks the first available key:
#   WEATHERAPI_KEY set       → weatherapi.com  (recommended)
#   OPENWEATHER_API_KEY set  → openweathermap.org
#   neither set              → open-meteo.com  (free, no key needed)
WEATHER_API_PROVIDER=auto

# ── WeatherAPI.com (recommended — richest data for Pakistan) ──────────────────
# Get a free key at: https://www.weatherapi.com/
# Free plan: 1 million calls/month, 3-day forecast
# Paid plan: up to 14-day forecast, historical data
WEATHERAPI_KEY=

# ── OpenWeatherMap (alternative) ─────────────────────────────────────────────
# Get a free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# How long to cache live weather responses in memory (seconds)
WEATHER_CACHE_TTL_SECONDS=600

# ── MC Dropout Inference ──────────────────────────────────────────────────────
#
#  MC Dropout runs N stochastic forward passes through the AE and TCN branches
#  in parallel (asyncio.gather) to estimate epistemic uncertainty. On timeout
#  or exception the request falls back to a single deterministic pass — the
#  fallback path is always safe; uncertainty fields are set to null in that case.

# Latency control — toggle and budget
# Set to false to disable MC entirely and revert to deterministic inference.
# All MC response fields will be null when disabled.
ENABLE_MC_INFERENCE=true
# Stochastic forward passes per branch per request.
# Range [5, 30]. Lower = faster (~300 ms for 5), higher = tighter uncertainty
# estimate. 15 is the validated production default (~1–1.5 s wall time).
MC_DROPOUT_SAMPLES=15
# Wall-clock timeout for the asyncio.gather across both branches (milliseconds).
# On exceed, falls back to deterministic single pass (degraded_reason: "timeout").
# Set below MC_DROPOUT_SAMPLES * avg_single_pass_ms to catch runaway TF threads.
MC_INFERENCE_TIMEOUT_MS=3000
# Max concurrent TF thread-pool workers across all simultaneous city requests.
# Higher = more throughput under load but increases peak RAM. 4 is safe for 8 GB.
MAX_CONCURRENT_MC_THREADS=4

# Uncertainty sensitivity — epistemic uncertainty blend weights
# AE and TCN epistemic uncertainty (CoV) are blended: result = AE_W * ae_cov + TCN_W * tcn_cov.
# Weights must sum to 1.0. AE is weighted higher (0.60) because the AE branch runs
# on every request; TCN is down-weighted for cities with short sequence histories.
MC_AE_UNCERTAINTY_WEIGHT=0.60
MC_TCN_UNCERTAINTY_WEIGHT=0.40
# Output clamp range for the blended epistemic_uncertainty field.
# Tighten the max (e.g. 0.80) to suppress extreme values on OOD inputs.
MC_UNCERTAINTY_MIN=0.0
MC_UNCERTAINTY_MAX=1.0

# Prediction stability thresholds — controls the prediction_stability label
# in responses: "stable" | "moderate_uncertainty" | "high_uncertainty".
# Thresholds use strict greater-than comparisons.
# Calibrate against your city's typical epistemic_uncertainty distribution.
MC_STABILITY_THRESHOLD_MODERATE=0.25
MC_STABILITY_THRESHOLD_HIGH=0.55

# Calibration audit — ECE bin count
# Number of equal-width bins used by scripts/calibration_audit.py to compute
# Expected Calibration Error (ECE). Matches the value recorded in calibration_audit.json.
# Changing this invalidates stored calibration_ece_test_set values.
CALIBRATION_ECE_BINS=15

# ── Runtime Health Collector ───────────────────────────────────────────────────
#
#  Three background asyncio tasks sample in-memory inference counters and the
#  DriftMonitor, then broadcast a SystemHealthSnapshot to /ws/health.
#  All state is in-memory and resets on restart — no DB writes.

# Background tick cadences (seconds)
HEALTH_TICK_INTERVAL_S=30
DRIFT_TICK_INTERVAL_S=300
CONFIDENCE_TICK_INTERVAL_S=3600

# Rolling window sizes (number of requests)
# HEALTH_MC_WINDOW_SIZE: last N predict_v2 calls used for MC success/timeout rates
# HEALTH_EPISTEMIC_BUFFER: last N successful MC inferences for uncertainty stats
HEALTH_MC_WINDOW_SIZE=100
HEALTH_EPISTEMIC_BUFFER=200

# MC success rate thresholds — fraction of recent requests that completed MC dropout
# (1.0 = perfect; lower means more timeouts/fallbacks than expected)
HEALTH_MC_DEGRADED=0.90
HEALTH_MC_CRITICAL=0.70

# Preprocessing failure rate thresholds — fraction where feature extraction raised
HEALTH_FAIL_DEGRADED=0.05
HEALTH_FAIL_CRITICAL=0.20

# Epistemic warmup: min successful MC inferences before per-city stability bands
# (2σ/3σ) can be computed from the observed distribution. "warming_up" until ready.
HEALTH_EPISTEMIC_WARMUP=50

# ── ML / Training ──────────────────────────────────────────────────────────────

# LSTM warm-up at startup (seed rolling buffers from historical data)
HYBRID_WARMUP=true
HYBRID_WARMUP_ROWS=14
HYBRID_WARMUP_CSV=backend/data/pakistan_weather_2000_2024.csv

# Model training defaults (overridable per city via CLI flags)
MODEL_BATCH_SIZE=64
MODEL_EPOCHS=100
THRESHOLD_K=2.5

# ── Secret Rotation Workflow ───────────────────────────────────────────────────
#
#  To rotate the JWT_SECRET_KEY:
#  1. Generate a new key:
#       python -c "import secrets; print(secrets.token_hex(32))"
#  2. Update JWT_SECRET_KEY in .env
#  3. Restart: docker compose restart hydroguard-api
#  4. All existing tokens are invalidated immediately. Users must log in again.
#
#  For zero-downtime rotation, accept both old + new key for one token
#  lifetime window, then drop the old key.
