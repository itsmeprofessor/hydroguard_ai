# ==============================================================================
#  HydroGuard-AI — Environment Variables Template
#  Copy to .env and fill in all REQUIRED values before running.
#  NEVER commit .env to version control — it contains secrets.
# ==============================================================================

# ── REQUIRED — application will refuse to start without these ─────────────────

# JWT signing key — must be cryptographically random, minimum 32 chars
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# PostgreSQL password (also used in DATABASE_URL below)
POSTGRES_PASSWORD=

# Redis auth password
REDIS_PASSWORD=

# Legacy admin token (for X-Admin-Token header auth, used by some dashboard flows)
ADMIN_TOKEN=

# ── OPTIONAL — have sensible defaults ─────────────────────────────────────────

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS — comma-separated allowed origins
# Use * only in development — with credentials it MUST be explicit origin(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — PostgreSQL for production, SQLite for local dev
DATABASE_URL=postgresql://hydroguard:${POSTGRES_PASSWORD}@postgres:5432/hydroguard
# DATABASE_URL=sqlite:///backend/weather_anomalies.db

# Redis (enables cross-worker WebSocket fan-out and rate-limit state sharing)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Live Weather API ───────────────────────────────────────────────────────────

# Provider: "auto" | "weatherapi" | "openweathermap" | "open-meteo"
# "auto" picks the first available key:
#   WEATHERAPI_KEY set       → weatherapi.com  (recommended)
#   OPENWEATHER_API_KEY set  → openweathermap.org
#   neither set              → open-meteo.com  (free, no key needed)
WEATHER_API_PROVIDER=auto

# ── WeatherAPI.com (recommended — richest data for Pakistan) ──────────────────
# Get a free key at: https://www.weatherapi.com/
# Free plan: 1 million calls/month, 3-day forecast
# Paid plan: up to 14-day forecast, historical data
WEATHERAPI_KEY=

# ── OpenWeatherMap (alternative) ─────────────────────────────────────────────
# Get a free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# How long to cache live weather responses in memory (seconds)
WEATHER_CACHE_TTL_SECONDS=600

# ── MC Dropout Inference ──────────────────────────────────────────────────────

# Set to false to revert to deterministic single-pass inference (safe rollback)
ENABLE_MC_INFERENCE=true
# Stochastic forward passes per branch per request (reduce to 5 for lower latency)
MC_DROPOUT_SAMPLES=15
# Wall-clock timeout per request in ms; fallback to deterministic on exceed
MC_INFERENCE_TIMEOUT_MS=3000
# Max concurrent TF thread-pool workers across all city requests
MAX_CONCURRENT_MC_THREADS=4

# ── ML / Training ──────────────────────────────────────────────────────────────

# LSTM warm-up at startup (seed rolling buffers from historical data)
HYBRID_WARMUP=true
HYBRID_WARMUP_ROWS=14
HYBRID_WARMUP_CSV=backend/data/pakistan_weather_2000_2024.csv

# Model training defaults (overridable per city via CLI flags)
MODEL_BATCH_SIZE=64
MODEL_EPOCHS=100
THRESHOLD_K=2.5

# ── Secret Rotation Workflow ───────────────────────────────────────────────────
#
#  To rotate the JWT_SECRET_KEY:
#  1. Generate a new key:
#       python -c "import secrets; print(secrets.token_hex(32))"
#  2. Update JWT_SECRET_KEY in .env
#  3. Restart: docker compose restart hydroguard-api
#  4. All existing tokens are invalidated immediately. Users must log in again.
#
#  For zero-downtime rotation, accept both old + new key for one token
#  lifetime window, then drop the old key.
