# ============================================================
#  HydroGuard-AI — Environment Configuration
#  Copy to .env and fill in values before running.
# ============================================================

# ------ API Server ------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ------ Security ------
# CHANGE before deploying publicly
ADMIN_TOKEN=changeme-set-in-env
# Comma-separated allowed origins (use * only in dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ------ Database ------
# SQLite (dev/local)
DATABASE_URL=sqlite:///backend/weather_anomalies.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://hydroguard:strongpass@postgres:5432/weather_anomalies

# ------ ML Model ------
# Override model hyperparameters (optional)
# MODEL_EPOCHS=100
# MODEL_BATCH_SIZE=64
# THRESHOLD_K=2.5

# ------ Hybrid LSTM warm-up ------
# Seed per-city LSTM sequence buffers from CSV on restart
HYBRID_WARMUP=true
HYBRID_WARMUP_ROWS=14
HYBRID_WARMUP_CSV=backend/data/pakistan_weather_2000_2024.csv
