# ============================================================
#  HydroGuard-AI — Environment Configuration
#  Copy to .env and fill in values before running.
#  Generate JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ------ API Server ------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ------ CORS (comma-separated; use specific origins in prod) ------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500

# ------ Auth / JWT ------
JWT_SECRET_KEY=CHANGE-ME-generate-with-secrets.token_hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Legacy admin token (still accepted for backward compat) ------
ADMIN_TOKEN=changeme-set-in-env

# ------ Database ------
# SQLite (dev/local)
DATABASE_URL=sqlite:///backend/weather_anomalies.db
# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql://hydroguard:strongpass@localhost:5432/hydroguard

# ------ Redis (required for multi-worker WS state in production) ------
# REDIS_URL=redis://:password@localhost:6379/0

# ------ ML Model ------
# MODEL_EPOCHS=100
# MODEL_BATCH_SIZE=64
# THRESHOLD_K=2.5

# ------ Hybrid LSTM warm-up ------
HYBRID_WARMUP=true
HYBRID_WARMUP_ROWS=14
HYBRID_WARMUP_CSV=backend/data/pakistan_weather_2000_2024.csv
